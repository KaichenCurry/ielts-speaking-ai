# ==========================================
# 雅思口语 AI 助教系统 - 环境变量配置
# ==========================================
# 复制此文件为 .env 并填写实际值

# Telegram Bot Token
# 获取方式：找 @BotFather 申请
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# MiniMax API Key
# 获取方式：https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here

# Notion Integration Token
# 获取方式：https://www.notion.so/my-integrations
# 需要创建 integration 并授权访问以下数据库：
# - 题库数据库
# - 作业反馈库
# - 错题本
NOTION_TOKEN=your_notion_integration_token_here

# ==========================================
# 数据库 ID（从 Notion URL 获取）
# ==========================================
# 题库：https://www.notion.so/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#                                    ↑ 这段是数据库 ID
NOTION_QUESTION_DB_ID=your_question_database_id_here
NOTION_HOMEWORK_DB_ID=your_homework_database_id_here
NOTION_BADCASE_DB_ID=your_badcase_database_id_here

# ==========================================
# 可选配置
# ==========================================
# 状态文件路径（默认：./memory/ielts_session.json）
# STATE_FILE_PATH=./memory/ielts_session.json

# 日志级别（DEBUG / INFO / WARNING）
# LOG_LEVEL=INFO
